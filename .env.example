# ─── Focalboard environment variables ────────────────────────────────────────
# Copy this file to .env and fill in the values for your deployment.
#
#   cp .env.example .env

# ── Focalboard ────────────────────────────────────────────────────────────────
# The public URL your friends will use to reach the server.
# Use http:// for plain HTTP or https:// when TLS is configured.
FOCALBOARD_SERVER_ROOT=http://your-domain-or-public-ip

# Host port that Focalboard listens on (only used by docker-compose.yml).
FOCALBOARD_PORT=8000

# ── PostgreSQL (only used by docker-compose.nginx.yml) ───────────────────────
POSTGRES_DB=boards
POSTGRES_USER=boardsuser
# IMPORTANT: Set this to a strong, unique password before deploying!
POSTGRES_PASSWORD=CHANGE_ME
